# ── LLM ─────────────────────────────────────────────────────────────────────
# Provider: openai | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
# If using Ollama locally:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=netguard
POSTGRES_PASSWORD=secret
POSTGRES_DB=netguard
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC_INPUT=raw.syscalls
KAFKA_TOPIC_OUTPUT=alerts.output
KAFKA_GROUP_ID=netguard-consumer

# ── ML ────────────────────────────────────────────────────────────────────────
ANOMALY_THRESHOLD=-0.05        # Isolation Forest score threshold (lower = more sensitive)
CONTAMINATION=0.01             # Expected anomaly rate for IF training
MODEL_DIR=ml/models/           # Where trained models are saved

# ── BETH replay ───────────────────────────────────────────────────────────────
BETH_DATA_DIR=data/beth/
REPLAY_SPEED=1000              # Events per second (-1 = max speed)

# ── RAG ───────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=rag/chroma_store/
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
